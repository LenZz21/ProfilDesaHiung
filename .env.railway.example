APP_NAME=ProfilDesa
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_URL=${{MySQL.MYSQL_URL}}

# Untuk hosting sementara, paling aman pakai mode sinkron
# agar tidak perlu service worker terpisah.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
FILESYSTEM_PUBLIC_URL=/storage

WHATSAPP_GATEWAY_BASE_URL=
WHATSAPP_GATEWAY_API_TOKEN=
WHATSAPP_NOTIFY_ON_LETTER_SUBMISSION=false
WHATSAPP_NOTIFY_ON_LETTER_STATUS=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
