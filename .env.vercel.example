APP_NAME=ProfilDesa
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-project.vercel.app
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=array
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=s3
FILESYSTEM_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
AWS_URL=

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

WHATSAPP_GATEWAY_BASE_URL=
WHATSAPP_GATEWAY_API_TOKEN=
WHATSAPP_NOTIFY_ON_LETTER_SUBMISSION=true
WHATSAPP_NOTIFY_ON_LETTER_STATUS=true
WHATSAPP_NOTIFY_LETTER_TEMPLATE="Halo {name}, pengajuan layanan \"{service_name}\" sudah kami terima dan saat ini sedang diproses oleh admin kampung. Nomor pengajuan: #{id}. Terima kasih."
WHATSAPP_NOTIFY_LETTER_ACCEPTED_TEMPLATE="Halo {name}, pengajuan layanan \"{service_name}\" sudah kami terima. Nomor pengajuan: #{id}."
WHATSAPP_NOTIFY_LETTER_PROCESS_TEMPLATE="Halo {name}, pengajuan \"{service_name}\" (#{id}) sedang diproses oleh admin kampung."
WHATSAPP_NOTIFY_LETTER_DONE_TEMPLATE="Halo {name}, pengajuan \"{service_name}\" (#{id}) sudah selesai diproses. Silakan hubungi admin untuk tindak lanjut."

WA_AUTO_REPLY_ENABLED=true
WA_AUTO_REPLY_TEXT="Halo {name}, pesan Anda sudah kami terima. Mohon tunggu, admin kami akan segera merespons."
WA_AUTO_REPLY_COOLDOWN_SECONDS=900
WA_AUTO_REPLY_IGNORE_NUMBERS=
