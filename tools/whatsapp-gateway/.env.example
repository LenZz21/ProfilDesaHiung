PORT=3070

# Optional bearer token for send-message endpoint.
API_TOKEN=

# Optional browser path if needed on Windows.
# Example:
# CHROME_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
CHROME_EXECUTABLE_PATH=

# Auto-reply saat ada chat masuk.
WA_AUTO_REPLY_ENABLED=true
WA_AUTO_REPLY_TEXT=Halo, pesan Anda sudah masuk ke Admin Kampung. Mohon tunggu, kami akan membalas secepatnya.
# Jeda kirim balasan otomatis ke nomor yang sama (detik)
WA_AUTO_REPLY_COOLDOWN_SECONDS=0
# Nomor yang tidak akan dibalas otomatis, pisahkan dengan koma.
# Contoh: 6281234567890,6281111111111
WA_AUTO_REPLY_IGNORE_NUMBERS=
# Tandai chat masuk sebagai sudah dibaca (unread hilang).
WA_MARK_AS_SEEN_ENABLED=true

# Interval watchdog koneksi (ms)
WA_HEALTHCHECK_INTERVAL_MS=30000
# Jika state tidak CONNECTED lebih lama dari ini, paksa reconnect (ms)
WA_UNHEALTHY_RECONNECT_AFTER_MS=120000
# Retry bind jika port 3070 bentrok (ms)
WA_SERVER_BIND_RETRY_MS=5000
